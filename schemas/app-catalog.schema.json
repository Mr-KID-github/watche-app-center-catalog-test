{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mr-kid-github.github.io/watche-app-center-catalog-test/schemas/app-catalog.schema.json",
  "title": "WatcheRobot App.Center Catalog",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "apps"],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "catalogId": {
      "type": "string",
      "minLength": 1
    },
    "updatedAt": {
      "type": "string"
    },
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/app"
      }
    }
  },
  "$defs": {
    "app": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "type", "version", "compat"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{1,62}$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "description": {
          "type": "string",
          "maxLength": 240
        },
        "type": {
          "enum": ["firmware-app", "manifest-app", "resource-app"]
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "packageUrl": {
          "type": "string"
        },
        "compat": {
          "$ref": "#/$defs/compat"
        },
        "firmware": {
          "$ref": "#/$defs/firmware"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "firmware-app"
              }
            }
          },
          "then": {
            "required": ["firmware"]
          }
        }
      ]
    },
    "compat": {
      "type": "object",
      "additionalProperties": true,
      "required": ["product", "chip", "flashSizeMb", "otaSlotSize", "minLauncherVersion"],
      "properties": {
        "product": {
          "const": "WatcheRobot"
        },
        "chip": {
          "enum": ["esp32s3", "esp32-s3"]
        },
        "flashSizeMb": {
          "type": "integer",
          "minimum": 1
        },
        "otaSlotSize": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4194304
        },
        "minLauncherVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "firmware": {
      "type": "object",
      "additionalProperties": true,
      "required": ["url", "sha256", "sizeBytes", "imageVersion"],
      "properties": {
        "url": {
          "type": "string",
          "pattern": "^https://"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4194304
        },
        "imageVersion": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "signature": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "algorithm": {
              "enum": ["unsigned-dev", "ecdsa-p256-sha256"]
            },
            "issuer": {
              "type": "string"
            },
            "value": {
              "type": "string"
            },
            "publicKeyPem": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}

